# LexGov News — Replit (https://replit.com)
# Após importar do GitHub: Run → o preview abre na Webview.

run = "npm run dev"
language = "nodejs"
modules = ["nodejs-20", "postgresql-16"]

[nix]
channel = "stable-24_05"

# Deploy: o Replit injeta PORT — não fixar -p no script "start" (ver package.json).
# build gera a app; run só sobe o servidor em modo produção.
[deployment]
run = ["sh", "-c", "npm run start"]
build = ["sh", "-c", "npm install && npm run build"]

[agent]
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
