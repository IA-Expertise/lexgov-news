generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Itens ingeridos do RSS por cidade (B). Fallback: mocks em `src/mocks/news.ts`.
model NewsArticle {
  id          String    @id @default(cuid())
  tenantSlug  String
  category    String
  title       String
  summary     String    @db.Text
  imageUrl    String    @default("")
  /// URL pública (ex.: /audio/louveira/xxx.mp3) após TTS ElevenLabs na ingestão
  audioUrl    String    @default("")
  sourceUrl   String    @unique
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantSlug])
  @@map("news_articles")
}

/// Metadados LIA por cidade (ex.: MP3 de menu/saudação gerado na ingestão).
model TenantLiaAsset {
  tenantSlug       String   @id
  /// Ex.: /audio/louveira/greeting.mp3
  greetingAudioUrl String   @default("")
  updatedAt        DateTime @updatedAt

  @@map("tenant_lia_assets")
}
