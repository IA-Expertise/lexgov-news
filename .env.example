# Produção (Replit Deploy etc.): a plataforma define PORT — o script "npm start" não fixa porta.
# Teste local em produção: npm run build && npx next start -H 0.0.0.0 (padrão porta 3000) ou PORT=5000 npm start

# Opcional: PostgreSQL (Replit Database ou externo). Sem isso, a app usa mocks.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Protege POST /api/ingest (ingestão RSS) e GET /api/agent/news (se AGENT_TOOL_SECRET vazio)
INGEST_SECRET="defina_um_segredo_longo"

# Opcional: só para /api/agent/news (senão usa INGEST_SECRET)
# AGENT_TOOL_SECRET="outro_segredo"

# Gemini — intermediário (/api/agent/intermediary) e classificação na ingestão (opcional)
# Use GEMINI_API_KEY OU AI_INTEGRATIONS_GEMINI_API_KEY (Replit)
# GEMINI_API_KEY=""
# AI_INTEGRATIONS_GEMINI_API_KEY=""
# Opcional: base URL (Replit / proxy)
# GEMINI_BASE_URL=""
# AI_INTEGRATIONS_GEMINI_BASE_URL=""
# Modelo (padrão gemini-2.5-flash)
# GEMINI_MODEL="gemini-2.5-flash"
# Classificar notícias com Gemini em POST /api/ingest (requer chave acima)
# INGEST_USE_GEMINI_CATEGORY=false

# Modo Diretor — /admin/login e /admin/[cidade] (lista + regerar TTS)
# ADMIN_SECRET="defina_uma_senha_forte"

# Armazenamento de MP3: local (padrão) — futuro R2/S3 via código em src/lib/storage
# AUDIO_STORAGE_ADAPTER=local

# ElevenLabs — TTS na ingestão (MP3 em public/audio/…)
# ELEVENLABS_API_KEY=""
# Padrão no código: eleven_flash_v2_5. Alternativas: eleven_multilingual_v2, eleven_turbo_v2 (só EN).
# ELEVENLABS_MODEL_ID="eleven_flash_v2_5"
# Por tenant (sobrescreve voiceId em tenants.ts): ELEVENLABS_VOICE_ID_LOUVEIRA=""
